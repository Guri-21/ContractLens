datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Document {
  id        String   @id @default(cuid())
  name      String
  type      String // e.g., MSA, SOW
  content   String
  createdAt DateTime @default(now())
  clauses   Clause[]
}

model Clause {
  id            String     @id @default(cuid())
  documentId    String
  document      Document   @relation(fields: [documentId], references: [id])
  text          String
  sectionNumber String?
  page          Int?
  tableData     Json?
  references    String[]
  overrides     String[]
  risks         Risk[]
  auditLogs     AuditLog[]
}

model Risk {
  id                   String   @id @default(cuid())
  clauseId             String
  clause               Clause   @relation(fields: [clauseId], references: [id])
  riskLevel            String
  reason               String
  playbookRuleViolated String?
  citationPage         Int?
  citationSection      String?
  createdAt            DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  clauseId  String
  clause    Clause   @relation(fields: [clauseId], references: [id])
  timestamp DateTime @default(now())
  actor     String // "ai" | "human"
  action    String
  before    String?
  after     String?
}

model PlaybookRule {
  id          String   @id @default(cuid())
  name        String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
