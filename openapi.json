          }
        ]
      }
    },
    "/api/audit/": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "List Audit Logs",
        "operationId": "list_audit_logs_api_audit__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
