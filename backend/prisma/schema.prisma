datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users User[]
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  hashed_password String
  role_id         String
  role            Role       @relation(fields: [role_id], references: [id])
  documents       Document[] @relation("UploadedDocuments")
  assigned_docs   Document[] @relation("AssignedDocuments")
  audit_logs      AuditLog[]
  notifications   Notification[]
}

model Document {
  id             String   @id @default(uuid())
  name           String
  document_type  String
  status         String
  file_path      String
  uploaded_by_id         String
  uploader               User                     @relation("UploadedDocuments", fields: [uploaded_by_id], references: [id])
  assigned_to_id         String?
  assigned_to            User?                    @relation("AssignedDocuments", fields: [assigned_to_id], references: [id])
  clauses                Clause[]
  missing_clauses        MissingMandatoryClause[]
  country_compliance     CountryLawCompliance[]
  financial_summary      FinancialSummary?
  approval               Approval?
}

model Clause {
  id             String          @id
  document_id    String
  document       Document        @relation(fields: [document_id], references: [id])
  document_name  String
  document_type  String
  section_number String?
  title          String?
  page           Int?
  text           String
  clause_type    String?
  references     Json?           @default("[]")
  overrides      Json?           @default("[]")
  table_data     Json?
  entities       Json?           @default("[]")
  embedding_id   String?
  risks          RiskFinding[]
  versions       ClauseVersion[]
}

model RiskFinding {
  id                     String  @id
  clause_id              String
  clause                 Clause  @relation(fields: [clause_id], references: [id])
  risk_level             String
  status                 String
  reason                 String
  playbook_rule_violated String?
  evidence               Json?   @default("[]")
  missing_documents      Json?
  redline                Json?
  contradiction_type     String?
  confidence             Float?
  comparison_text        Json?
}

model PlaybookRule {
  id          String  @id @default(uuid())
  title       String
  description String
  is_active   Boolean @default(true)
}

model CountryComplianceRule {
  id               String  @id @default(uuid())
  country_code     String
  rule_title       String
  rule_description String
  is_active        Boolean @default(true)
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  action      String
  target_type String
  target_id   String?
  timestamp   DateTime @default(now())
}

model ClauseVersion {
  id             String   @id @default(uuid())
  clause_id      String
  clause         Clause   @relation(fields: [clause_id], references: [id])
  version_number Int
  text           String
  edited_by      String?
  edited_at      DateTime @default(now())
  change_type    String
}

model MissingMandatoryClause {
  id          String   @id @default(uuid())
  document_id String
  document    Document @relation(fields: [document_id], references: [id])
  clause_name String
  present     Boolean
}

model CountryLawCompliance {
  id          String   @id @default(uuid())
  document_id String
  document    Document @relation(fields: [document_id], references: [id])
  law_name    String
  status      String
  details     String?
}

model FinancialSummary {
  id              String   @id @default(uuid())
  document_id     String   @unique
  document        Document @relation(fields: [document_id], references: [id])
  contract_value  String?
  penalty         String?
  payment_terms   String?
  liability_cap   String?
  warranty_period String?
}

model Approval {
  id               String    @id @default(uuid())
  document_id      String    @unique
  document         Document  @relation(fields: [document_id], references: [id])
  status           String
  reason           String?
  reviewer_notes   String?
  internal_remarks String?
  decided_by       String?
  decided_at       DateTime?
}

model Notification {
  id                  String   @id @default(uuid())
  user_id             String
  user                User     @relation(fields: [user_id], references: [id])
  type                String
  message             String
  created_at          DateTime @default(now())
  read                Boolean  @default(false)
  related_document_id String?
}
